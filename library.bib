@article{djukic_austrian_2025,
	title = {Austrian nitrogen budget following {UNECE} guidance},
	volume = {20},
	issn = {1748-9326},
	url = {https://iopscience.iop.org/article/10.1088/1748-9326/adf2bd},
	doi = {10.1088/1748-9326/adf2bd},
	abstract = {Human activity over the past century has greatly disrupted the natural nitrogen (N) balance, harming health and the environment. Sustainable nitrogen management requires cross-sectoral governance, but studies tracking nitrogen flows across sectors are limited. This study assesses cross-sectoral sources, flows, and sinks of reactive nitrogen (Nr) in Austria, identifying direct Nr inputs and emitting sectors. Using the ‘UNECE-Guidance Document on National Nitrogen Budgets’ and material flow analysis, we quantified Austria’s national nitrogen budget for 2015–2019. Results show the main nitrogen inflows and outflows from imports and exports in the consumer goods and chemical industries. Energy imports also contribute significantly. Some nitrogen is temporarily stored (e.g. in products) or transferred between sectors. However, not all of this N-loss is of direct environmental concern. Annually, 389 kt Nr are lost directly to the environment and causing significant environmental and economic consequences. Direct Nr inputs primarily originate from agriculture (39.3\%) and energy/transport (20.7\%), with around 30\% from cross-border fluxes via water (13.9\%) and air (16.6\%). The remaining 10\% stem from settlements, waste management, and industry. This study highlights the complexity of nitrogen sources and sinks in Austria and underscores the need for improvements towards reduced uncertainties in future research, including higher-resolution spatial data to account for regional variability.},
	language = {en},
	number = {9},
	urldate = {2025-09-24},
	journal = {Environmental Research Letters},
	author = {Djukic, Ika and Broneder, Carina and Dirnböck, Thomas and Gabriel, Oliver and Lindinger, Helga and Loishandl-Weisz, Harald and Mayer, Simone and Nagl, Christian and Poupa, Stephan and Rechberger, Helmut and Sander, Philip and Schwarzl, Bettina and Tanzer, Julia and Weiss, Peter and Winiwarter, Wilfried},
	month = sep,
	year = {2025},
	keywords = {nitrogen, Østerrike, nitrogenbalanse, N-artikkel},
	pages = {094054},
	file = {PDF:/Users/anja/Zotero/storage/A8A6HECF/Djukic et al. - 2025 - Austrian nitrogen budget following UNECE guidance.pdf:application/pdf},
}

